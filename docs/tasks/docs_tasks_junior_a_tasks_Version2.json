{
  "engineer": {
    "id": "junior_a",
    "role": "Backend Engineer",
    "stack": ["Go", "PostgreSQL", "Docker"]
  },
  "traceability_protocol": {
    "version": "1.0",
    "objective": "Ensure every backend change is reproducible, auditable, and understandable by any LLM/agent or human reviewer.",
    "required_artifacts_per_task": [
      "docs/traceability/junior_a/<slice_id>/<task_id>/worklog.md",
      "docs/traceability/junior_a/<slice_id>/<task_id>/change_manifest.json",
      "docs/traceability/junior_a/<slice_id>/<task_id>/test_evidence.md",
      "docs/traceability/junior_a/<slice_id>/<task_id>/handoff.md"
    ],
    "worklog_template_rules": {
      "must_include_sections": [
        "Task Header",
        "Intent",
        "Files Changed",
        "API/Contract Impact",
        "DB/Migration Impact",
        "Implementation Notes",
        "Risks and Tradeoffs",
        "Next Step"
      ],
      "task_header_fields": [
        "slice_id",
        "task_id",
        "engineer_id",
        "branch_name",
        "commit_shas",
        "date_utc",
        "status"
      ]
    },
    "change_manifest_schema": {
      "slice_id": "string",
      "task_id": "string",
      "engineer_id": "junior_a",
      "branch": "string",
      "commits": ["string"],
      "files_added": ["string"],
      "files_modified": ["string"],
      "files_deleted": ["string"],
      "api_endpoints_added": ["METHOD /path"],
      "api_endpoints_modified": ["METHOD /path"],
      "api_endpoints_removed": ["METHOD /path"],
      "migrations_added": ["string"],
      "env_vars_added": ["string"],
      "breaking_changes": ["string"],
      "related_tasks": ["string"],
      "pr_number": "number|null"
    },
    "test_evidence_rules": {
      "must_include": [
        "Exact command executed",
        "Test scope (unit/integration/manual)",
        "Observed output summary",
        "Failure notes (if any)",
        "Retest evidence after fix"
      ],
      "manual_test_format": [
        "Preconditions",
        "Steps",
        "Expected Result",
        "Actual Result"
      ]
    },
    "handoff_rules": {
      "must_include": [
        "What is done",
        "What is pending",
        "How frontend should consume this change",
        "Known limitations",
        "Rollback plan"
      ]
    },
    "naming_conventions": {
      "slice_id_format": "S0|S1|S2|S3|S4|S5",
      "task_id_format": "A-S<slice_number>-T<nn>",
      "branch_format": "feat/<task_id>-<short-kebab-desc>",
      "commit_message_format": "<task_id>: <imperative summary>",
      "artifact_path_format": "docs/traceability/junior_a/<slice_id>/<task_id>/..."
    },
    "status_model": [
      "todo",
      "in_progress",
      "blocked",
      "ready_for_review",
      "done"
    ],
    "update_frequency": {
      "worklog": "at least once per day and on every status change",
      "change_manifest": "updated with every commit batch",
      "test_evidence": "updated after every test run",
      "handoff": "required before PR review request"
    },
    "cross_agent_linking_rules": {
      "every_task_must_reference": [
        "upstream_dependency_task_ids",
        "downstream_consumer_task_ids"
      ],
      "consumer_example": "If backend adds endpoint, reference Junior B task consuming that endpoint.",
      "link_format": "A-Sx-Tnn -> B-Sx-Tnn"
    },
    "review_gate_checklist": [
      "All required artifacts exist",
      "change_manifest matches actual diff",
      "OpenAPI updated when endpoint changed",
      "Migration and rollback notes present when DB changed",
      "Test evidence included and reproducible",
      "Handoff complete and linked to dependent task"
    ]
  },
  "definition_of_done": [
    "Implementation completed for task scope",
    "All traceability artifacts created and complete",
    "Tests pass and evidence logged",
    "Dependencies and downstream tasks linked",
    "PR opened with task_id and artifact links"
  ],

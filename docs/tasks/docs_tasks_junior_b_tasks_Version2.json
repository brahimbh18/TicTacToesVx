{
  "engineer": {
    "id": "junior_b",
    "role": "Android Engineer",
    "stack": ["Java", "Android", "MVVM"]
  },
  "traceability_protocol": {
    "version": "1.0",
    "objective": "Ensure every Android/UI integration change is reproducible, auditable, and understandable by any LLM/agent or human reviewer.",
    "required_artifacts_per_task": [
      "docs/traceability/junior_b/<slice_id>/<task_id>/worklog.md",
      "docs/traceability/junior_b/<slice_id>/<task_id>/change_manifest.json",
      "docs/traceability/junior_b/<slice_id>/<task_id>/test_evidence.md",
      "docs/traceability/junior_b/<slice_id>/<task_id>/handoff.md"
    ],
    "worklog_template_rules": {
      "must_include_sections": [
        "Task Header",
        "Intent",
        "Files Changed",
        "Screen/Flow Impact",
        "API Consumption Impact",
        "State Management Notes",
        "Risks and Tradeoffs",
        "Next Step"
      ],
      "task_header_fields": [
        "slice_id",
        "task_id",
        "engineer_id",
        "branch_name",
        "commit_shas",
        "date_utc",
        "status"
      ]
    },
    "change_manifest_schema": {
      "slice_id": "string",
      "task_id": "string",
      "engineer_id": "junior_b",
      "branch": "string",
      "commits": ["string"],
      "files_added": ["string"],
      "files_modified": ["string"],
      "files_deleted": ["string"],
      "screens_added_or_changed": ["string"],
      "viewmodels_added_or_changed": ["string"],
      "repositories_added_or_changed": ["string"],
      "endpoints_consumed": ["METHOD /path"],
      "ui_states_added": ["loading|success|error|empty|disabled"],
      "breaking_ui_changes": ["string"],
      "related_tasks": ["string"],
      "pr_number": "number|null"
    },
    "test_evidence_rules": {
      "must_include": [
        "Build command and variant",
        "Device/emulator details",
        "Manual test matrix by screen",
        "Network scenarios tested (success/error/timeout/unauthorized)",
        "Screenshots or textual output summary"
      ],
      "manual_test_format": [
        "Preconditions",
        "Steps",
        "Expected Result",
        "Actual Result"
      ]
    },
    "handoff_rules": {
      "must_include": [
        "What is done",
        "What backend contract version was used",
        "What is pending",
        "Known UI limitations",
        "Fallback behavior for API failures"
      ]
    },
    "naming_conventions": {
      "slice_id_format": "S0|S1|S2|S3|S4|S5",
      "task_id_format": "B-S<slice_number>-T<nn>",
      "branch_format": "feat/<task_id>-<short-kebab-desc>",
      "commit_message_format": "<task_id>: <imperative summary>",
      "artifact_path_format": "docs/traceability/junior_b/<slice_id>/<task_id>/..."
    },
    "status_model": [
      "todo",
      "in_progress",
      "blocked",
      "ready_for_review",
      "done"
    ],
    "update_frequency": {
      "worklog": "at least once per day and on every status change",
      "change_manifest": "updated with every commit batch",
      "test_evidence": "updated after every test run",
      "handoff": "required before PR review request"
    },
    "cross_agent_linking_rules": {
      "every_task_must_reference": [
        "upstream_dependency_task_ids",
        "downstream_consumer_task_ids"
      ],
      "upstream_example": "If UI consumes endpoint, link the backend task that implements it.",
      "link_format": "B-Sx-Tnn -> A-Sx-Tnn (upstream)"
    },
    "review_gate_checklist": [
      "All required artifacts exist",
      "change_manifest matches actual diff",
      "api-mapping.md updated when endpoint consumption changes",
      "UI states documented for error/loading/empty",
      "Test evidence included and reproducible",
      "Handoff complete and linked to upstream/downstream tasks"
    ]
  },
  "definition_of_done": [
    "Implementation completed for task scope",
    "All traceability artifacts created and complete",
    "Build and manual test evidence logged",
    "Dependencies and upstream backend tasks linked",
    "PR opened with task_id and artifact links"
  ],

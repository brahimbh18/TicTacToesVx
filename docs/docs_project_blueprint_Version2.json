      "internal/domain/invitation/entity.go",
      "internal/domain/invitation/repository.go",
      "internal/domain/invitation/service.go",
      "internal/domain/match/entity.go",
      "internal/domain/match/repository.go",
      "internal/domain/match/service.go",
      "internal/domain/match/rules.go",
      "internal/domain/ai/service.go",
      "internal/domain/ai/minimax.go",
      "internal/domain/ai/heuristic.go",
      "internal/domain/ai/random.go",
      "internal/repository/postgres/user_repo.go",
      "internal/repository/postgres/friend_repo.go",
      "internal/repository/postgres/invitation_repo.go",
      "internal/repository/postgres/match_repo.go",
      "internal/security/jwt.go",
      "internal/security/password.go",
      "internal/shared/errors/errors.go",
      "internal/shared/types/common.go",
      "pkg/logger/logger.go",
      "docs/api/openapi.yaml",
      "docs/architecture/backend-tree.md",
      "docs/architecture/data-model.md",
      "docs/architecture/vertical-slices.md",
      "Dockerfile",

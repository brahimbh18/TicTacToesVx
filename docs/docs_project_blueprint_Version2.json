{
  "project": {
    "name": "TicTacToesVx",
    "repo": "brahimbh18/TicTacToesVx",
    "date": "2026-04-24",
    "architecture": {
      "frontend": "Android Java MVVM",
      "backend": "Go + PostgreSQL + Docker",
      "development_style": "vertical_slices",
      "llm_optimized": true
    }
  },
  "api": {
    "base_path": "/api/v1",
    "error_format": {
      "error": {
        "code": "string",
        "message": "string"
      }
    },
    "endpoints": [
      {
        "tag": "auth",
        "method": "POST",
        "path": "/auth/register",
        "auth_required": false,
        "request_body": {
          "username": "string",
          "password": "string"
        },
        "responses": {
          "201": {
            "id": "uuid",
            "username": "string",
            "token": "jwt"
          }
        }
      },
      {
        "tag": "auth",
        "method": "POST",
        "path": "/auth/login",
        "auth_required": false,
        "request_body": {
          "username": "string",
          "password": "string"
        },
        "responses": {
          "200": {
            "id": "uuid",
            "username": "string",
            "token": "jwt"
          }
        }
      },
      {
        "tag": "users",
        "method": "GET",
        "path": "/users/me",
        "auth_required": true,
        "responses": {
          "200": {
            "id": "uuid",
            "username": "string"
          }
        }
      },
      {
        "tag": "users",
        "method": "GET",
        "path": "/users/search",
        "auth_required": true,
        "query_params": {
          "username": "string"
        },
        "responses": {
          "200": [
            {
              "id": "uuid",
              "username": "string"
            }
          ]
        }
      },
      {
        "tag": "friends",
        "method": "GET",
        "path": "/friends",
        "auth_required": true,
        "responses": {
          "200": [
            {
              "id": "uuid",
              "username": "string"
            }
          ]
        }
      },
      {
        "tag": "friends",
        "method": "POST",
        "path": "/friends/requests",
        "auth_required": true,
        "request_body": {
          "toUserId": "uuid"
        },
        "responses": {
          "201": {
            "requestId": "uuid",
            "status": "pending"
          }
        }
      },
      {
        "tag": "friends",
        "method": "GET",
        "path": "/friends/requests/incoming",
        "auth_required": true,
        "responses": {
          "200": [
            {
              "requestId": "uuid",
              "fromUser": {
                "id": "uuid",
                "username": "string"
              },
              "status": "pending"
            }
          ]
        }
      },
      {
        "tag": "friends",
        "method": "POST",
        "path": "/friends/requests/{requestId}/accept",
        "auth_required": true,
        "path_params": {
          "requestId": "uuid"
        },
        "responses": {
          "200": {
            "ok": true
          }
        }
      },
      {
        "tag": "friends",
        "method": "POST",
        "path": "/friends/requests/{requestId}/decline",
        "auth_required": true,
        "path_params": {
          "requestId": "uuid"
        },
        "responses": {
          "200": {
            "ok": true
          }
        }
      },
      {
        "tag": "invitations",
        "method": "POST",
        "path": "/invitations",
        "auth_required": true,
        "request_body": {
          "inviteeUserId": "uuid",
          "boardSize": "integer"
        },
        "responses": {
          "201": {
            "invitationId": "uuid",
            "status": "pending"
          }
        }
      },
      {
        "tag": "invitations",
        "method": "GET",
        "path": "/invitations/incoming",
        "auth_required": true,
        "responses": {
          "200": [
            {
              "invitationId": "uuid",
              "fromUser": {
                "id": "uuid",
                "username": "string"
              },
              "boardSize": "integer"
            }
          ]
        }
      },
      {
        "tag": "invitations",
        "method": "POST",
        "path": "/invitations/{invitationId}/accept",
        "auth_required": true,
        "path_params": {
          "invitationId": "uuid"
        },
        "responses": {
          "200": {
            "matchId": "uuid"
          }
        }
      },
      {
        "tag": "invitations",
        "method": "POST",
        "path": "/invitations/{invitationId}/decline",
        "auth_required": true,
        "path_params": {
          "invitationId": "uuid"
        },
        "responses": {
          "200": {
            "ok": true
          }
        }
      },
      {
        "tag": "matches",
        "method": "POST",
        "path": "/matches",
        "auth_required": true,
        "request_body": {
          "mode": "online_friend|online_random|ai|local",
          "boardSize": "integer",
          "aiDifficulty": "easy|medium|hard|null",
          "inviteeUserId": "uuid|null"
        },
        "responses": {
          "201": {
            "matchId": "uuid",
            "status": "waiting|active",
            "boardSize": "integer",
            "players": [
              {
                "userId": "uuid",
                "symbol": "X|O"
              }
            ],
            "nextTurn": "X|O"
          }
        }
      },
      {
        "tag": "matches",
        "method": "GET",
        "path": "/matches/{matchId}",
        "auth_required": true,
        "path_params": {
          "matchId": "uuid"
        },
        "responses": {
          "200": {
            "matchId": "uuid",
            "status": "waiting|active|finished",
            "boardSize": "integer",
            "board": ["string"],
            "nextTurn": "X|O",
            "winner": "X|O|draw|null"
          }
        }
      },
      {
        "tag": "matches",
        "method": "POST",
        "path": "/matches/{matchId}/moves",
        "auth_required": true,
        "path_params": {
          "matchId": "uuid"
        },
        "request_body": {
          "cellIndex": "integer"
        },
        "responses": {
          "200": {
            "applied": true,
            "board": ["string"],
            "nextTurn": "X|O",
            "winner": "X|O|draw|null",
            "status": "active|finished"
          }
        }
      },
      {
        "tag": "matches",
        "method": "POST",
        "path": "/matches/{matchId}/resign",
        "auth_required": true,
        "path_params": {
          "matchId": "uuid"
        },
        "responses": {
          "200": {
            "ok": true,
            "winner": "X|O"
          }
        }
      }
    ]
  },
